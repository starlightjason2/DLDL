# Local development template — full variable set (same keys as `.env.example`).
# Copy to `.env.local` and symlink `.env` → `.env.local`, or copy to `.env` directly.
# Paths below are relative to the project root unless absolute.
# PBS sets PBS_JOBID and PBS_NODEFILE on compute nodes (not listed here).

# --- Repo / launcher (required by scripts/*.sh) ---
PROJECT_ROOT=/eagle/fusiondl_aesp/starlightjason2/DLDL 

# --- Data paths (preprocess, train, validate) ---
DATA_DIR=/eagle/fusiondl_aesp/signal_data/d3d/ipspr15V
LABELS_PATH=/eagle/fusiondl_aesp/starlightjason2/DLDL/data/ips_labels.txt
DATA_PATH=data/processed_data/processed_dataset_meanvar-whole.pt
TRAIN_LABELS_PATH=data/processed_data/processed_labels_meanvar-whole.pt
PROG_DIR=data/train_progress/


# --- Preprocessing ---
CPU_USE=0.2
PREPROCESSOR_MAX_WORKERS=4
DATALOADER_NUM_WORKERS=4

# --- Training hyperparameters (train.py / model/cnn.py) ---
LEARNING_RATE=0.0244755225090038
NUM_EPOCHS=200
DROPOUT_RATE=0.6641600193527787
WEIGHT_DECAY=6.678279694104745e-07
BATCH_SIZE=32
GRADIENT_CLIP=9.852492430191496
LR_SCHEDULER=True
LR_SCHEDULER_FACTOR=0.7170656196716738
LR_SCHEDULER_PATIENCE=6
EARLY_STOPPING_PATIENCE=21
# Positive-class (disruptive) weight in BCE loss. >1 favors recall (fewer missed disruptions) at the cost of more false positives.
CLS_POS_WEIGHT=1.427719386863257

# Beta for the F-beta score that drives model selection and the HPTune objective
# (the tuner maximizes validation F-beta). beta>1 weights recall over precision;
# F2 (beta=2) weights recall 2x. Not tuned — this defines the objective itself.
FBETA=2.0
DECISION_THRESHOLD=0.5

# --- CNN architecture (train.py → IpCNN) ---
CONV1_FILTERS=16
CONV1_KERNEL=9
CONV1_PADDING=4
CONV2_FILTERS=32
CONV2_KERNEL=5
CONV2_PADDING=2
CONV3_FILTERS=64
CONV3_KERNEL=3
CONV3_PADDING=1
CONV4_FILTERS=128
CONV4_KERNEL=3
CONV4_PADDING=1
POOL_SIZE=4
FC1_SIZE=120
FC2_SIZE=60

# --- Bayesian HPTune search space (required for hptune_serial) ---
HPTUNE_LR_MIN=5e-6
HPTUNE_LR_MAX=0.03
HPTUNE_DROPOUT_MIN=0.0
HPTUNE_DROPOUT_MAX=0.7
HPTUNE_ALLOWED_EPOCHS=25,50,100,150,200,300
HPTUNE_NUM_INITIAL_TRIALS=15
HPTUNE_WEIGHT_DECAY_LOG_MIN=-8.0
HPTUNE_WEIGHT_DECAY_LOG_MAX=-1.0
HPTUNE_ALLOWED_BATCH_SIZES=16,32,64,128,256
HPTUNE_GRADIENT_CLIP_MIN=0.0
HPTUNE_GRADIENT_CLIP_MAX=10.0
HPTUNE_LR_SCHEDULER_FACTOR_MIN=0.05
HPTUNE_LR_SCHEDULER_FACTOR_MAX=0.95
HPTUNE_LR_SCHEDULER_PATIENCE_MIN=1
HPTUNE_LR_SCHEDULER_PATIENCE_MAX=40
HPTUNE_EARLY_STOPPING_PATIENCE_MIN=1
HPTUNE_EARLY_STOPPING_PATIENCE_MAX=80
HPTUNE_CLS_POS_WEIGHT_MIN=1.0
HPTUNE_CLS_POS_WEIGHT_MAX=10.0
HPTUNE_DECISION_THRESHOLD_MIN=0.05
HPTUNE_DECISION_THRESHOLD_MAX=0.5
HPTUNE_RANDOM_INSERT_EVERY=5
HPTUNE_EI_XI=0.05

# --- HPTune run layout and PBS chain ---
HPTUNE_DIR=data/hptune
HPTUNE_MAX_TRIALS=10
# The serial chain needs 1 running + 1 queued job: use `debug`, not `debug-scaling` (1 job total).
HPTUNE_QUEUE=debug
HPTUNE_TRAIN_WALLTIME=1:00:00
HPTUNE_CHAIN_ID=local_chain
HPTUNE_MAX_RETRIES=2
TRIAL_TIMEOUT=1800

# --- Conda / runtime (scripts/*.sh) ---
DLDL_CONDASH=/soft/applications/conda/2025-09-25/mconda3/etc/profile.d/conda.sh
CONDA_ENV=base
TMPDIR=/tmp

# --- Thread caps (recommended on crowded nodes) ---
OPENBLAS_NUM_THREADS=1
OMP_NUM_THREADS=1
MKL_NUM_THREADS=1
NUMEXPR_NUM_THREADS=1
TORCH_NUM_THREADS=1
