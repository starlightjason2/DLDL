# Allow committing the best-trial model checkpoint(s) and the CSV logs (trial state
# and chain step history). Each parent directory must be un-ignored before a file can
# be re-included (git can't un-ignore a file whose parent dir is excluded), and these
# negations come after `*.pt` / `*.csv` so they win.
!data/
data/*
!data/hptune/
data/hptune/*
!data/hptune/trials/
data/hptune/trials/*
!data/hptune/trials/trials.csv
!data/hptune/trials/chain_steps.csv
!data/hptune/trials/best_trial/
data/hptune/trials/best_trial/*
!data/hptune/trials/best_trial/*_best_params.pt

