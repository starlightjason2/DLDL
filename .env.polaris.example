# Polaris HPC environment variables for DLDL
# Copy this file to .env.polaris and modify paths as needed
# Typical Polaris paths structure

# Raw data directory containing individual shot files (one .txt file per shot)
DATA_DIR=/lus/eagle/projects/fusiondl_aesp/signal_data/d3d/ipspr15V/

# Directory where preprocessed datasets and metadata are stored
DATASET_DIR=/lus/eagle/projects/fusiondl_aesp/jrodriguez/processed_data/

# Path to labels file containing shot numbers and disruption times
LABELS_PATH=/lus/eagle/projects/fusiondl_aesp/jrodriguez/shot_lists/ips_labels.txt

# Preprocessed dataset file for training
DATA_PATH=/lus/eagle/projects/fusiondl_aesp/jrodriguez/processed_data/processed_dataset_meanvar-whole.pt

# Preprocessed labels file for training
TRAIN_LABELS_PATH=/lus/eagle/projects/fusiondl_aesp/jrodriguez/processed_data/processed_labels_scaled_labels.pt

# File containing the maximum sequence length across all shots

# Directory for saving training progress, checkpoints, and logs
PROG_DIR=/lus/eagle/projects/fusiondl_aesp/jrodriguez/train_progress/

# Unique identifier for this training run (used in filenames)
JOB_ID=test_lr0005

# Scaled labels filename (used in preprocessing scripts)
SCALED_LABELS_FILENAME=processed_labels_scaled_labels.pt
