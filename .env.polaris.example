# Polaris HPC environment variables for DLDL
# Copy this file to .env.polaris and modify paths as needed
# Typical Polaris paths structure

CPU_USE=0.2

# Raw data directory containing individual shot files (one .txt file per shot)
DATA_DIR=/eagle/fusiondl_aesp/signal_data/d3d/ipspr15V/

# Path to labels file containing shot numbers and disruption times
LABELS_PATH=/eagle/fusiondl_aesp/jrodriguez/shot_lists/ips_labels.txt

# Preprocessed dataset tensor (.pt) — full path
DATA_PATH=/eagle/fusiondl_aesp/starlightjason2/DLDL/data/processed_data/processed_dataset_meanvar-whole.pt

# Preprocessed labels tensor (.pt) — full path
TRAIN_LABELS_PATH=/eagle/fusiondl_aesp/starlightjason2/DLDL/data/processed_labels_scaled_labels.pt

# Directory for training logs, checkpoints, and graph.py outputs
PROG_DIR=/eagle/fusiondl_aesp/starlightjason2/DLDL/data/train_progress/

# Unique identifier for this training run (used in filenames)
JOB_ID=test_lr0005

# Limit the number of threads used by OpenBLAS 
OPENBLAS_NUM_THREADS=1

# --- Hyperparameter tuning (scripts/start_hptune.sh, start_hptune_parallel.sh) ---
# HPTUNE_QUEUE must be a valid Polaris *top-level* queue (check: qstat -Q, or ALCF docs).
# Common mistakes: HPTUNE_QUEUE=small → qsub: Unknown queue ("small" is routed under prod, not a -q name).
# Examples: debug, debug-scaling (short / few nodes), prod (production; routes to small/medium/large pools).
HPTUNE_QUEUE=debug-scaling
HPTUNE_DIR=/eagle/fusiondl_aesp/starlightjason2/DLDL/data/hptune
TRIALS_DIR=/eagle/fusiondl_aesp/starlightjason2/DLDL/data/hptune/trials
DB_CONNECTION=sqlite:////eagle/fusiondl_aesp/starlightjason2/DLDL/data/hptune/trials/trials_log.db
NUM_SLOTS=1
HPTUNE_CONTROLLER_NODES=4
HPTUNE_TRIAL_NODES=1
HPTUNE_CONTROLLER_WALLTIME=01:00:00
HPTUNE_TRAIN_WALLTIME=01:00:00
HPTUNE_MAX_TRIALS=10
GPUS_PER_NODE=4
# Conda for controller / trials (set in your real .env)
# DLDL_CONDASH=/path/to/miniconda3/etc/profile.d/conda.sh
# CONDA_ENV=your_env
