# Polaris-oriented template (same keys as `.env.example`). Copy to `.env.polaris` and symlink `.env` → `.env.polaris`, or merge into `.env`.
# All keys are read explicitly by the code (no hidden defaults). PBS_JOBID is set by the scheduler on compute nodes only.

PROJECT_ROOT=/eagle/fusiondl_aesp/starlightjason2/DLDL
PYTHONPATH=/eagle/fusiondl_aesp/starlightjason2/DLDL/src

DATA_DIR=/eagle/fusiondl_aesp/signal_data/d3d/ipspr15V/
LABELS_PATH=/eagle/fusiondl_aesp/jrodriguez/shot_lists/ips_labels.txt
DATA_PATH=/eagle/fusiondl_aesp/starlightjason2/DLDL/data/processed_data/processed_dataset_meanvar-whole.pt
TRAIN_LABELS_PATH=/eagle/fusiondl_aesp/starlightjason2/DLDL/data/processed_labels_scaled_labels.pt
PROG_DIR=/eagle/fusiondl_aesp/starlightjason2/DLDL/data/train_progress/
JOB_ID=test_lr0005

NORMALIZATION_TYPE=meanvar-whole
CPU_USE=0.2
PREPROCESSOR_MAX_WORKERS=4

EARLY_STOPPING_PATIENCE=10
LEARNING_RATE=0.0005
NUM_EPOCHS=200
LOG_INTERVAL=50
WEIGHT_DECAY=0.0001
DROPOUT_RATE=0.35
BATCH_SIZE=128
LR_SCHEDULER=true
LR_SCHEDULER_FACTOR=0.5
LR_SCHEDULER_PATIENCE=5
GRADIENT_CLIP=1.0
DATALOADER_NUM_WORKERS=4

CONV1_FILTERS=16
CONV1_KERNEL=9
CONV1_PADDING=4
CONV2_FILTERS=32
CONV2_KERNEL=5
CONV2_PADDING=2
CONV3_FILTERS=64
CONV3_KERNEL=3
CONV3_PADDING=1
POOL_SIZE=4
FC1_SIZE=120
FC2_SIZE=60

HPTUNE_LR_MIN=5e-6
HPTUNE_LR_MAX=0.03
HPTUNE_DROPOUT_MIN=0.0
HPTUNE_DROPOUT_MAX=0.7
HPTUNE_ALLOWED_EPOCHS=25,50,100,150,200,300
HPTUNE_NUM_INITIAL_TRIALS=15
HPTUNE_WEIGHT_DECAY_LOG_MIN=-8.0
HPTUNE_WEIGHT_DECAY_LOG_MAX=-1.0
HPTUNE_ALLOWED_BATCH_SIZES=16,32,64,128,256
HPTUNE_GRADIENT_CLIP_MIN=0.0
HPTUNE_GRADIENT_CLIP_MAX=10.0
HPTUNE_LR_SCHEDULER_FACTOR_MIN=0.05
HPTUNE_LR_SCHEDULER_FACTOR_MAX=0.95
HPTUNE_LR_SCHEDULER_PATIENCE_MIN=1
HPTUNE_LR_SCHEDULER_PATIENCE_MAX=40
HPTUNE_EARLY_STOPPING_PATIENCE_MIN=1
HPTUNE_EARLY_STOPPING_PATIENCE_MAX=80

HPTUNE_DIR=/eagle/fusiondl_aesp/starlightjason2/DLDL/data/hptune
DB_CONNECTION=sqlite:////eagle/fusiondl_aesp/starlightjason2/DLDL/data/hptune/trials/trials_log.db

# HPTUNE_QUEUE must be a valid Polaris top-level queue (e.g. debug-scaling, prod).
HPTUNE_MAX_TRIALS=100
HPTUNE_QUEUE=debug-scaling
HPTUNE_CONTROLLER_WALLTIME=1:00:00
HPTUNE_TRAIN_WALLTIME=1:00:00
# Non-empty HPTUNE_CHAIN_ID: train.py qsub's the next controller; omit or leave empty to disable
HPTUNE_QSUB_ACCOUNT=fusiondl_aesp
HPTUNE_CHAIN_ID=chain_placeholder
HPTUNE_TRIAL_NODES=2
HPTUNE_CONTROLLER_NODES=4
HPTUNE_MAX_RETRIES=2
HPTUNE_RANDOM_INSERT_EVERY=5
HPTUNE_EI_XI=0.05
TRIAL_TIMEOUT=1800
GPUS_PER_NODE=4

RANK=0
WORLD_SIZE=1
LOCAL_RANK=0

DLDL_CONDASH=/soft/applications/conda/2025-09-25/mconda3/etc/profile.d/conda.sh
CONDA_ENV=base
TMPDIR=/tmp

OPENBLAS_NUM_THREADS=1
OMP_NUM_THREADS=1
MKL_NUM_THREADS=1
NUMEXPR_NUM_THREADS=1
TORCH_NUM_THREADS=1

MPICH_GPU_SUPPORT_ENABLED=1
TORCH_NCCL_TRACE_BUFFER_SIZE=2000
TORCH_NCCL_DUMP_ON_TIMEOUT=1
