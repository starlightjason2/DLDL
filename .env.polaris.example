# Polaris / Eagle template (same keys as `.env.example`).
# Copy to `.env.polaris` and symlink `.env` → `.env.polaris`, or copy to `.env` directly.
# PBS sets PBS_JOBID on compute nodes (not listed here).
# HP_TUNE_MODE is set by scripts/start_arch_tune.sh (not in `.env`).
# TRIAL_DIR is only used for a manual single-trial run via scripts/run_train.sh (not in `.env`).

# --- Repo / launcher (required by scripts/*.sh) ---
PROJECT_ROOT=/eagle/fusiondl_aesp/starlightjason2/DLDL

# --- Data paths (preprocess, train, validate, graph) ---
DATA_DIR=/eagle/fusiondl_aesp/signal_data/d3d/ipspr15V/
LABELS_PATH=/eagle/fusiondl_aesp/starlightjason2/DLDL/data/ips_labels.txt
DATA_PATH=/eagle/fusiondl_aesp/starlightjason2/DLDL/data/processed_data/processed_dataset_meanvar-whole.pt
TRAIN_LABELS_PATH=/eagle/fusiondl_aesp/starlightjason2/DLDL/data/processed_data/processed_labels_meanvar-whole.pt
PROG_DIR=/eagle/fusiondl_aesp/starlightjason2/DLDL/data/train_progress/
JOB_ID=my_run

# --- Preprocessing ---
CPU_USE=0.2
PREPROCESSOR_MAX_WORKERS=4

# --- Training hyperparameters (train.py / model/cnn.py) ---
EARLY_STOPPING_PATIENCE=10
LEARNING_RATE=0.0005
NUM_EPOCHS=200
LOG_INTERVAL=50
WEIGHT_DECAY=0.0001
DROPOUT_RATE=0.35
BATCH_SIZE=128
LR_SCHEDULER=true
LR_SCHEDULER_FACTOR=0.5
LR_SCHEDULER_PATIENCE=5
GRADIENT_CLIP=1.0
DATALOADER_NUM_WORKERS=4
# Positive-class (disruptive) weight in BCE loss. >1 favors recall. Tunable via HP_TUNE_CLS_POS_WEIGHT_*.
CLS_POS_WEIGHT=3.0
# Sigmoid probability cutoff for the disruptive class. Fixed (not tuned).
DECISION_THRESHOLD=0.5
# Precision floor for checkpoint selection and the HP tune objective.
MIN_PRECISION=0.90
# F-beta for model selection (best checkpoint + early stopping) and the HP tune objective (maximized). beta>1 favors recall.
FBETA=1.8

# --- CNN architecture (train.py → IpCNN) ---
CONV1_FILTERS=64
CONV1_KERNEL=7
CONV1_PADDING=3
CONV2_FILTERS=128
CONV2_KERNEL=7
CONV2_PADDING=3
CONV3_FILTERS=32
CONV3_KERNEL=5
CONV3_PADDING=2
CONV4_FILTERS=64
CONV4_KERNEL=7
CONV4_PADDING=3
POOL_SIZE=8
FC1_SIZE=72
FC2_SIZE=72

# --- Bayesian HP tune search space (required for hp_tune_serial) ---
HP_TUNE_LR_MIN=5e-6
HP_TUNE_LR_MAX=0.03
HP_TUNE_DROPOUT_MIN=0.0
HP_TUNE_DROPOUT_MAX=0.7
HP_TUNE_ALLOWED_EPOCHS=25,50,100,150,200,300
HP_TUNE_NUM_INITIAL_TRIALS=15
HP_TUNE_WEIGHT_DECAY_LOG_MIN=-8.0
HP_TUNE_WEIGHT_DECAY_LOG_MAX=-1.0
HP_TUNE_ALLOWED_BATCH_SIZES=16,32,64,128,256
HP_TUNE_GRADIENT_CLIP_MIN=0.0
HP_TUNE_GRADIENT_CLIP_MAX=10.0
HP_TUNE_LR_SCHEDULER_FACTOR_MIN=0.05
HP_TUNE_LR_SCHEDULER_FACTOR_MAX=0.95
HP_TUNE_LR_SCHEDULER_PATIENCE_MIN=1
HP_TUNE_LR_SCHEDULER_PATIENCE_MAX=40
HP_TUNE_EARLY_STOPPING_PATIENCE_MIN=1
HP_TUNE_EARLY_STOPPING_PATIENCE_MAX=30
HP_TUNE_CLS_POS_WEIGHT_MIN=1.0
HP_TUNE_CLS_POS_WEIGHT_MAX=4
HP_TUNE_RANDOM_INSERT_EVERY=5
HP_TUNE_EI_XI=0.05

# --- HP tune run layout and PBS chain ---
HP_TUNE_DIR=/eagle/fusiondl_aesp/starlightjason2/DLDL/data/hp_tune
HP_TUNE_MAX_TRIALS=100
# HP_TUNE_QUEUE must be a valid Polaris top-level queue. Serial chain needs 1 running + 1 queued: use `debug`, not `debug-scaling`.
HP_TUNE_QUEUE=debug
HP_TUNE_TRAIN_WALLTIME=1:00:00
HP_TUNE_MAX_RETRIES=2
TRIAL_TIMEOUT=1800

# --- Architecture HP tune (HP_TUNE_MODE=architecture; training hparams fixed from above) ---
ARCH_TUNE_DIR=/eagle/fusiondl_aesp/starlightjason2/DLDL/data/arch_tune
ARCH_TUNE_CONV_FILTERS=8,16,32,64,128,256
ARCH_TUNE_KERNELS=3,5,7,9,11
ARCH_TUNE_POOL_SIZES=2,4,8
ARCH_TUNE_FC1_MIN=64
ARCH_TUNE_FC1_MAX=512
ARCH_TUNE_FC2_MIN=32
ARCH_TUNE_FC2_MAX=256
ARCH_TUNE_NUM_INITIAL_TRIALS=10
ARCH_TUNE_RANDOM_INSERT_EVERY=5
ARCH_TUNE_EI_XI=0.05

# --- Conda / runtime (scripts/*.sh) ---
DLDL_CONDASH=/soft/applications/conda/2025-09-25/mconda3/etc/profile.d/conda.sh
CONDA_ENV=dldl
TMPDIR=/tmp

# --- Thread caps (recommended on crowded PBS nodes) ---
OPENBLAS_NUM_THREADS=1
OMP_NUM_THREADS=1
MKL_NUM_THREADS=1
NUMEXPR_NUM_THREADS=1
TORCH_NUM_THREADS=1
