# Local development environment variables for DLDL
# Copy this file to .env.local and modify paths as needed
# Note: These are relative paths from the project root directory

# Raw data directory containing individual shot files (one .txt file per shot)
DATA_DIR=data/eagle/fusiondl_aesp/signal_data/d3d/ipspr15V/

# Directory where preprocessed datasets and metadata are stored
DATASET_DIR=data/eagle/fusiondl_aesp/processed_data/

# Path to labels file containing shot numbers and disruption times
LABELS_PATH=data/eagle/fusiondl_aesp/shot_lists/ips_labels.txt

# Preprocessed dataset file for training
DATA_PATH=data/eagle/fusiondl_aesp/processed_data/processed_dataset_meanvar-whole.pt

# Preprocessed labels file for training
TRAIN_LABELS_PATH=data/eagle/fusiondl_aesp/processed_data/processed_labels_scaled_labels.pt

# File containing the maximum sequence length across all shots

# Directory for saving training progress, checkpoints, and logs
PROG_DIR=data/eagle/fusiondl_aesp/train_progress/

# Unique identifier for this training run (used in filenames)
JOB_ID=test_lr0005

# Optional: normalization method + dataset_id (scale, meanvar-whole, meanvar-single). Default: meanvar-whole
# NORMALIZATION_TYPE=meanvar-whole

# Optional: fraction of CPU cores for preprocessing (0-1). Use 0.2-0.3 for ~32GB RAM. Default: 0.2
# CPU_USE=0.2
