# Template: copy to `.env` and replace `/path/to/DLDL` with your repo root.
# Every variable below is read explicitly by Python entry points or PBS shell scripts.
# PBS sets PBS_JOBID and PBS_NODEFILE on compute nodes (not listed here).
# TRIAL_DIR is only used for a manual single-trial run via scripts/run_train.sh (not in `.env`).

# --- Repo / launcher (required by scripts/*.sh) ---
PROJECT_ROOT=/path/to/DLDL

# --- Data paths (preprocess, train, validate) ---
DATA_DIR=/path/to/raw/signals/
LABELS_PATH=/path/to/labels.txt
DATA_PATH=/path/to/processed_dataset.pt
TRAIN_LABELS_PATH=/path/to/processed_labels.pt
PROG_DIR=/path/to/train_progress/
JOB_ID=my_run

# --- Preprocessing ---
CPU_USE=0.2
PREPROCESSOR_MAX_WORKERS=4

# --- Training hyperparameters (train.py / model/cnn.py) ---
EARLY_STOPPING_PATIENCE=21
LEARNING_RATE=0.0244755225090038
NUM_EPOCHS=200
LOG_INTERVAL=50
WEIGHT_DECAY=6.678279694104735e-07
DROPOUT_RATE=0.6641600193527787
BATCH_SIZE=32
LR_SCHEDULER=true
LR_SCHEDULER_FACTOR=0.7170656196716738
LR_SCHEDULER_PATIENCE=6
GRADIENT_CLIP=9.852492430191496
DATALOADER_NUM_WORKERS=4
# Positive-class (disruptive) weight in BCE loss. >1 favors recall.
CLS_POS_WEIGHT=1.427719386863257
# Sigmoid probability cutoff for the disruptive class. Fixed (not tuned).
DECISION_THRESHOLD=0.5
# Precision floor for checkpoint selection and HPTune (maximize recall above this).
MIN_PRECISION=0.90
# F-beta logged in training CSV only (not used for selection).
FBETA=1.5

# --- CNN architecture (train.py → IpCNN) ---
CONV1_FILTERS=64
CONV1_KERNEL=7
CONV1_PADDING=3
CONV2_FILTERS=128
CONV2_KERNEL=7
CONV2_PADDING=3
CONV3_FILTERS=32
CONV3_KERNEL=5
CONV3_PADDING=2
CONV4_FILTERS=64
CONV4_KERNEL=7
CONV4_PADDING=3
POOL_SIZE=8
FC1_SIZE=72
FC2_SIZE=72

# --- Bayesian HPTune search space (required for hptune_serial) ---
HPTUNE_LR_MIN=5e-6
HPTUNE_LR_MAX=0.03
HPTUNE_DROPOUT_MIN=0.0
HPTUNE_DROPOUT_MAX=0.7
HPTUNE_ALLOWED_EPOCHS=25,50,100,150,200,300
HPTUNE_NUM_INITIAL_TRIALS=15
HPTUNE_WEIGHT_DECAY_LOG_MIN=-8.0
HPTUNE_WEIGHT_DECAY_LOG_MAX=-1.0
HPTUNE_ALLOWED_BATCH_SIZES=16,32,64,128,256
HPTUNE_GRADIENT_CLIP_MIN=0.0
HPTUNE_GRADIENT_CLIP_MAX=10.0
HPTUNE_LR_SCHEDULER_FACTOR_MIN=0.05
HPTUNE_LR_SCHEDULER_FACTOR_MAX=0.95
HPTUNE_LR_SCHEDULER_PATIENCE_MIN=1
HPTUNE_LR_SCHEDULER_PATIENCE_MAX=40
HPTUNE_EARLY_STOPPING_PATIENCE_MIN=1
HPTUNE_EARLY_STOPPING_PATIENCE_MAX=30
HPTUNE_CLS_POS_WEIGHT_MIN=1.0
HPTUNE_CLS_POS_WEIGHT_MAX=4


HPTUNE_RANDOM_INSERT_EVERY=5
HPTUNE_EI_XI=0.05

# --- HPTune run layout and PBS chain ---
# Trial dirs: $HPTUNE_DIR/trials/trial_*
# Trial log CSV: $HPTUNE_DIR/trials/trials.csv
# Controller logs: $HPTUNE_DIR/controller_logs/
HPTUNE_DIR=/path/to/DLDL/data/hptune
HPTUNE_MAX_TRIALS=100
# The serial chain needs 1 running + 1 queued job: use `debug`, not `debug-scaling` (1 job total).
HPTUNE_QUEUE=debug
HPTUNE_TRAIN_WALLTIME=1:00:00
HPTUNE_MAX_RETRIES=2
TRIAL_TIMEOUT=1800

# --- Architecture HPTune (HPTUNE_MODE=architecture; training hparams fixed from .env) ---
# Use scripts/start_arch_hptune.sh (sets HPTUNE_MODE and ARCH_HPTUNE_DIR).
ARCH_HPTUNE_DIR=/path/to/DLDL/data/arch_hptune
ARCH_HPTUNE_CONV_FILTERS=8,16,32,64,128,256
ARCH_HPTUNE_KERNELS=3,5,7,9,11
ARCH_HPTUNE_POOL_SIZES=2,4,8
ARCH_HPTUNE_FC1_MIN=64
ARCH_HPTUNE_FC1_MAX=512
ARCH_HPTUNE_FC2_MIN=32
ARCH_HPTUNE_FC2_MAX=256
ARCH_HPTUNE_NUM_INITIAL_TRIALS=10
ARCH_HPTUNE_RANDOM_INSERT_EVERY=5
ARCH_HPTUNE_EI_XI=0.05

# --- Conda / runtime (scripts/*.sh) ---
DLDL_CONDASH=/path/to/conda/etc/profile.d/conda.sh
CONDA_ENV=base
TMPDIR=/tmp

# --- Thread caps (recommended on crowded PBS nodes) ---
OPENBLAS_NUM_THREADS=1
OMP_NUM_THREADS=1
MKL_NUM_THREADS=1
NUMEXPR_NUM_THREADS=1
TORCH_NUM_THREADS=1
