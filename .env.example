# Template: copy to `.env` and replace `/path/to/DLDL` with your repo root.
# Every variable below is read explicitly by Python entry points or PBS shell scripts.
# PBS sets PBS_JOBID and PBS_NODEFILE on compute nodes (not listed here).
# TRIAL_DIR is set by scripts/controller.sh during HP-tune trial jobs (not in `.env`).

# --- Repo / launcher (required by scripts/*.sh) ---
PROJECT_ROOT=/path/to/DLDL

# --- Data paths (preprocess, train, validate) ---
DATA_DIR=/path/to/raw/signals/
LABELS_PATH=/path/to/labels.txt
DATA_PATH=/path/to/processed_dataset.pt
TRAIN_LABELS_PATH=/path/to/processed_labels.pt
PROG_DIR=/path/to/train_progress/
JOB_ID=my_run

# --- Preprocessing ---
NORMALIZATION_TYPE=meanvar-whole
CPU_USE=0.2
PREPROCESSOR_MAX_WORKERS=4

# --- Training hyperparameters (train.py / model/cnn.py) ---
EARLY_STOPPING_PATIENCE=10
LEARNING_RATE=0.0005
NUM_EPOCHS=200
LOG_INTERVAL=50
WEIGHT_DECAY=0.0001
DROPOUT_RATE=0.35
BATCH_SIZE=128
LR_SCHEDULER=true
LR_SCHEDULER_FACTOR=0.5
LR_SCHEDULER_PATIENCE=5
GRADIENT_CLIP=1.0
DATALOADER_NUM_WORKERS=4

# --- CNN architecture (train.py → IpCNN) ---
CONV1_FILTERS=16
CONV1_KERNEL=9
CONV1_PADDING=4
CONV2_FILTERS=32
CONV2_KERNEL=5
CONV2_PADDING=2
CONV3_FILTERS=64
CONV3_KERNEL=3
CONV3_PADDING=1
POOL_SIZE=4
FC1_SIZE=120
FC2_SIZE=60

# --- Bayesian HPTune search space (required for hptune_serial) ---
HPTUNE_LR_MIN=5e-6
HPTUNE_LR_MAX=0.03
HPTUNE_DROPOUT_MIN=0.0
HPTUNE_DROPOUT_MAX=0.7
HPTUNE_ALLOWED_EPOCHS=25,50,100,150,200,300
HPTUNE_NUM_INITIAL_TRIALS=15
HPTUNE_WEIGHT_DECAY_LOG_MIN=-8.0
HPTUNE_WEIGHT_DECAY_LOG_MAX=-1.0
HPTUNE_ALLOWED_BATCH_SIZES=16,32,64,128,256
HPTUNE_GRADIENT_CLIP_MIN=0.0
HPTUNE_GRADIENT_CLIP_MAX=10.0
HPTUNE_LR_SCHEDULER_FACTOR_MIN=0.05
HPTUNE_LR_SCHEDULER_FACTOR_MAX=0.95
HPTUNE_LR_SCHEDULER_PATIENCE_MIN=1
HPTUNE_LR_SCHEDULER_PATIENCE_MAX=40
HPTUNE_EARLY_STOPPING_PATIENCE_MIN=1
HPTUNE_EARLY_STOPPING_PATIENCE_MAX=80
HPTUNE_RANDOM_INSERT_EVERY=5
HPTUNE_EI_XI=0.05

# --- HPTune run layout and PBS chain ---
# Trial dirs: $HPTUNE_DIR/trials/trial_*
# Trial log CSV: $HPTUNE_DIR/trials/trials.csv
# Controller logs: $HPTUNE_DIR/controller_logs/
HPTUNE_DIR=/path/to/DLDL/data/hptune
HPTUNE_MAX_TRIALS=100
HPTUNE_QUEUE=debug-scaling
HPTUNE_CONTROLLER_WALLTIME=1:00:00
HPTUNE_TRAIN_WALLTIME=1:00:00
HPTUNE_CHAIN_ID=chain_placeholder
HPTUNE_TRIAL_NODES=2
HPTUNE_CONTROLLER_NODES=4
HPTUNE_MAX_RETRIES=2
TRIAL_TIMEOUT=1800

# --- Conda / runtime (scripts/*.sh) ---
DLDL_CONDASH=/path/to/conda/etc/profile.d/conda.sh
CONDA_ENV=base
TMPDIR=/tmp

# --- Distributed training (scripts/run_train.sh) ---
NRANKS_PER_NODE=4

# --- Thread caps (recommended on crowded PBS nodes) ---
OPENBLAS_NUM_THREADS=1
OMP_NUM_THREADS=1
MKL_NUM_THREADS=1
NUMEXPR_NUM_THREADS=1
TORCH_NUM_THREADS=1

# --- Optional: MPI / NCCL hints (Polaris multi-GPU; see `.env.polaris.example`) ---
# MPICH_GPU_SUPPORT_ENABLED=1
# TORCH_NCCL_TRACE_BUFFER_SIZE=2000
# TORCH_NCCL_DUMP_ON_TIMEOUT=1
# REDIS_HOST=localhost
